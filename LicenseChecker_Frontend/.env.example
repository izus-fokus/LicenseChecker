# VirusTotal public API key for SHA256 file scanning before upload.
# Get a free key at https://www.virustotal.com/gui/sign-in
# If this variable is not set, the VirusTotal check is skipped.
VITE_VIRUSTOTAL_API_KEY=your_api_key_here

# Maximum allowed size for zip file uploads in MB.
# If this variable is not set, the default limit of 50 MB applies.
VITE_ZIP_UPLOAD_LIMIT_MB=50
